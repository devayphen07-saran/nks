{
  "codeQualityStandards": {
    "typescript": {
      "strictMode": true,
      "rules": {
        "noExplicitAny": {
          "enabled": true,
          "severity": "error",
          "message": "Avoid 'any' types. Use specific interfaces from src/common/types/"
        },
        "explicitReturnTypes": {
          "enabled": true,
          "severity": "error",
          "message": "All functions must have explicit return types"
        },
        "explicitParameterTypes": {
          "enabled": true,
          "severity": "error",
          "message": "All parameters must have explicit types"
        }
      }
    },
    "logging": {
      "rules": {
        "noConsoleInProduction": {
          "enabled": true,
          "severity": "error",
          "allowedFiles": ["seeders/", ".spec.ts"],
          "message": "Use NestJS Logger instead of console.log()"
        },
        "errorLoggingRequired": {
          "enabled": true,
          "severity": "warning",
          "message": "All catch blocks must log error details"
        }
      }
    },
    "constants": {
      "rules": {
        "noMagicNumbers": {
          "enabled": true,
          "severity": "warning",
          "ignoredNumbers": [0, 1, -1, 2],
          "message": "Use constants from src/common/constants/app-constants.ts"
        },
        "noHardcodedStrings": {
          "enabled": true,
          "severity": "warning",
          "ignoredPatterns": ["^[a-z_]+@[a-z_]+\\.[a-z]+$"],
          "message": "Use constants for business logic strings"
        }
      }
    },
    "security": {
      "rules": {
        "noPasswordLogging": {
          "enabled": true,
          "severity": "error",
          "sensitiveFields": [
            "password",
            "token",
            "secret",
            "apiKey",
            "otpHash"
          ],
          "message": "Never log sensitive data"
        },
        "noLocalhostInProduction": {
          "enabled": true,
          "severity": "warning",
          "allowedInEnvironments": ["development", "test"],
          "message": "Use environment variables for URLs, not hardcoded localhost"
        },
        "otpSecurityRequirement": {
          "enabled": true,
          "severity": "error",
          "requirement": "OTP must be hashed before storage",
          "message": "Use bcrypt to hash OTP values"
        }
      }
    },
    "errorHandling": {
      "rules": {
        "nothrowWithoutContext": {
          "enabled": true,
          "severity": "error",
          "message": "Always provide descriptive error messages"
        },
        "noSilentFallbacks": {
          "enabled": true,
          "severity": "warning",
          "message": "Log error before falling back to alternative logic"
        },
        "transactionSafety": {
          "enabled": true,
          "severity": "error",
          "requirement": "All database writes must be in transactions",
          "message": "Use TransactionService for atomic operations"
        }
      }
    },
    "codeDuplication": {
      "rules": {
        "maxDuplicationPercentage": 3,
        "ignoredPatterns": ["test", "spec"],
        "message": "Code duplication > 3% detected. Extract to shared utility."
      }
    }
  },
  "files": {
    "constants": {
      "location": "src/common/constants/app-constants.ts",
      "purpose": "Centralized configuration for all magic numbers and strings"
    },
    "types": {
