# ═══════════════════════════════════════════════════════════════
# NKS BACKEND ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# NEVER commit secrets to git. Copy this to .env.local and fill in values.
# ═══════════════════════════════════════════════════════════════

# DATABASE CONFIGURATION
DATABASE_URL=postgresql://postgres:password@localhost:5432/pos-db?schema=public

# APP CONFIGURATION
PORT=4000
NODE_ENV=development
BETTER_AUTH_SECRET=your_better_auth_secret_min_32_chars_change_in_production
BETTER_AUTH_BASE_URL=http://localhost:4000

# CORS CONFIGURATION (comma-separated, no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# JWT CONFIGURATION
JWT_ACCESS_SECRET=your_jwt_access_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# GOOGLE OAUTH CONFIGURATION
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# MSG91 CONFIGURATION
# Get credentials from https://www.msg91.com/user/api
# NEVER commit real credentials - use AWS Secrets Manager in production
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_WIDGET_ID=your_msg91_widget_id
MSG91_BASE_URL=https://control.msg91.com/api/v5/widget

# AWS CONFIGURATION (for Secrets Manager)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ENCRYPTION CONFIGURATION
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_do_not_commit_to_git

# TOKEN HASHING SECRETS (HMAC-SHA256)
# Generate with: openssl rand -hex 32
# WARNING: Changing these invalidates all existing sessions/OTPs
OTP_HMAC_SECRET=your_otp_hmac_secret_change_in_production
REFRESH_TOKEN_HMAC_SECRET=your_refresh_token_hmac_secret_change_in_production
IP_HMAC_SECRET=your_ip_hmac_secret_change_in_production

# REDIS CONFIGURATION (for background job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SEED CONFIGURATION
INIT=false

# LOGGING CONFIGURATION
LOG_LEVEL=debug
LOG_FORMAT=json

# ENVIRONMENT
NODE_ENV=development
